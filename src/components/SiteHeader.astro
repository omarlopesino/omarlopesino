---
import Menu from './ui/Menu.astro';
import MenuLink from './ui/MenuLink.astro';
import Logo from './ui/Logo.astro';
import LanguageSwitcher from './ui/LanguageSwitcher.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

---
<Menu>
  <Logo slot="logo" />
  <MenuLink href="/blog">{t('nav.blog')}</MenuLink>
  <MenuLink href="/about">{t('nav.about')}</MenuLink>
  <MenuLink href="/contact" class="px-4 rounded-lg border border-current">{t('nav.contact')}</MenuLink>
  <li><LanguageSwitcher lang={lang} /></li>
</Menu>
