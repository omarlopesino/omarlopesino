---
import { getLangFromUrl, useFormatDate } from '@/i18n/utils';

interface Props {
    pubDate: string,
    class?: string;
    [key: string]: unknown;
}

const lang = getLangFromUrl(Astro.url);
const formatDate = useFormatDate(lang);
const { class: className, pubDate, ...rest } = Astro.props;

---
<time datetime={pubDate} class="text-sm" {...rest}>{formatDate(pubDate)}</time>