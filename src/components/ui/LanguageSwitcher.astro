---
let classes : Record<string, string[]> = {
    "es": [],
    "en": []
}

let linkClasses = 'p-1 rounded';

const { lang: lang } = Astro.props;

if (Array.isArray(classes[lang])) {
    classes[lang].push("font-bold");
}

---
<span class="hover:bg-transparent"><a href="/en" class:list={[classes.en, linkClasses]}>en</a> / <a href="/es" class:list={[classes.es, linkClasses]}>es</a></span>
