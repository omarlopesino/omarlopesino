---
import { Image } from 'astro:assets';
import Bubble from './Bubble.astro';
import Share from './Share.astro';
import { getLangFromUrl, useTranslations, useFormatDate } from '@/i18n/utils';

interface Props {
  title: string;
  description: string;
  url: string;
  date: string
  tags?: string[];
  class?: string;
  image: {
    src: string;
    alt: string;
    width: number;
    height: number;
  },
  [key: string]: unknown;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const formatDate = useFormatDate(lang);

const { class: className, title, description, url, date, image, tags = [], ...rest } = Astro.props;

const shareId = `share_${crypto.randomUUID()}`;
---

<article class:list={['prose', className]} {...rest}>
    <h1 class="m-0 text-center">{title}</h1>
    <Image src={image.src} alt={image.alt} width={image.width} height={image.height} class="mx-auto w-full aspect-[21/9] object-cover mb-2" />
    <div class="flex items-center gap-3 justify-center">
        <time datetime={date} class="text-sm">{formatDate(date)}</time>
        <ul class="flex gap-3 list-none p-0! m-0!" aria-label={t('post.tagsLabel')}>
            {
                tags.map((tag) => (
                    <li class="m-0 p-0"><Bubble class:list={['badge-accent']}>{tag}</Bubble></li>
                ))
            }
        </ul>
    </div>
    <p>{description}</p>
    <slot name="content"></slot>
    <div class="flex flex-col items-center">
        <h2 class="mt-0! mb-2 text-base font-normal">{t('post.shareTitle')}</h2>
        <Share class="align-middle" id={shareId} url={url} title={title} text={description} />
    </div>
</article>
