---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  refresh?: string;
  lang?: string;
}

const { title, description, refresh, lang } = Astro.props;

const locales = ['en', 'es'];
const defaultLocale = 'en';
const origin = Astro.site?.origin ?? Astro.url.origin;
const restPath = Astro.url.pathname.replace(/^\/(en|es)(?=\/|$)/, '') || '/';
const canonical = `${origin}${Astro.url.pathname}`;
const alternates = locales.map((code) => ({ code, href: `${origin}/${code}${restPath}` }));
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    {alternates.map(({ code, href }) => <link rel="alternate" hreflang={code} href={href} />)}
    <link rel="alternate" hreflang="x-default" href={`${origin}/${defaultLocale}${restPath}`} />
    {refresh && <noscript><meta http-equiv="refresh" content={refresh} /></noscript>}
    <title>{title}</title>
  </head>
  <body class="max-w-5xl mx-auto">
    <header class="lg:px-4">
      <Header />
    </header>
    <main class="my-6 px-6">
      <slot />
    </main>
    <footer class="lg:px-4">
      <Footer />
    </footer>
  </body>
</html>
